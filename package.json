{
  "name": "lab-go",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite",
    "fmt": "oxfmt",
    "lint": "tsc --noEmit && oxlint .",
